{
  "ConnectionStrings": {
    "Default": "Data Source=fmc.db"
  },
  "Jwt": {
    "Key": "development-key-change-in-production-min-32chars!",
    "Issuer": "FMC",
    "Audience": "FmcClients",
    "ExpiryMinutes": 60
  },
  "Media": {
    "UploadRoot": "uploads",
    "PublicUrlPath": "/media",
    "MaxFileSizeBytes": 5242880
  },
  "Discovery": {
    "PremiumEnterpriseRankingBoostMeters": 2500,
    "FreeTierMaxResults": 10,
    "PremiumTierMaxResults": 50,
    "FreeTierMaxRadiusKm": 5,
    "PremiumTierMaxRadiusKm": 15
  },
  "Cors": {
    "AllowedOrigins": [],
    "AllowedMethods": [ "GET", "POST", "PUT", "PATCH", "DELETE", "OPTIONS" ],
    "AllowedHeaders": [ "Authorization", "Content-Type", "Accept", "X-Correlation-Id" ]
  },
  "RateLimiting": {
    "AuthPermitLimit": 10,
    "AuthWindowSeconds": 60,
    "UploadPermitLimit": 5,
    "UploadWindowSeconds": 60
  },
  "Demo": {
    "AllowRegistration": true,
    "EnableSwagger": false
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning",
        "System": "Warning"
      }
    },
    "WriteTo": [
      { "Name": "Console" }
    ],
    "Enrich": [ "FromLogContext" ]
  },
  "AllowedHosts": "*"
}
